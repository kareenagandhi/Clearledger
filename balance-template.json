{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.6",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "TextBlock",
          "text": "ClearLedger",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "TextBlock",
          "text": "${month} ${year}",
          "spacing": "None",
          "isSubtle": true,
          "size": "Small"
        }
      ]
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Income",
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "${income}",
              "size": "Large",
              "weight": "Bolder",
              "color": "Good"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Spent",
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "${spent}",
              "size": "Large",
              "weight": "Bolder",
              "color": "Attention"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Saved: ${saved} (${savingsRate}%)",
      "weight": "Bolder",
      "color": "Good",
      "horizontalAlignment": "Center",
      "spacing": "Medium"
    }
  ]
}
