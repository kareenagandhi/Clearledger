{
  "name": "ClearLedger — Personal Finance",
  "short_name": "ClearLedger",
  "description": "Track income, expenses, budgets, bills and investments in one place. AI-powered insights to help you save more.",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "theme_color": "#7c3aed",
  "background_color": "#0d0b14",
  "lang": "en",
  "dir": "ltr",
  "categories": ["finance", "productivity"],
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshot-mobile.png",
      "sizes": "412x915",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "ClearLedger Dashboard — Mobile View"
    },
    {
      "src": "screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "ClearLedger Dashboard — Desktop View"
    }
  ],
  "shortcuts": [
    {
      "name": "Add Transaction",
      "short_name": "Add",
      "url": "/?action=add-transaction",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "View Dashboard",
      "short_name": "Dashboard",
      "url": "/",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/?import=csv",
      "accept": {
        "text/csv": [".csv"]
      }
    },
    {
      "action": "/?import=json",
      "accept": {
        "application/json": [".json"]
      }
    },
    {
      "action": "/?import=ofx",
      "accept": {
        "application/x-ofx": [".ofx", ".qfx"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+clearledger",
      "url": "/?protocol=%s"
    },
    {
      "protocol": "web+finance",
      "url": "/?protocol=%s"
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://clearledger.vercel.app/manifest.json"
    }
  ],
  "prefer_related_applications": false,
  "iarc_rating_id": "",
  "widgets": [
    {
      "name": "ClearLedger Balance",
      "description": "Quick view of your monthly income, spending, and savings",
      "tag": "clearledger-balance",
      "template": "clearledger-balance-template",
      "ms_ac_template": "widgets/balance-template.json",
      "data": "widgets/balance-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "screenshot-mobile.png",
          "sizes": "412x915",
          "label": "Balance widget showing monthly summary"
        }
      ],
      "icons": [
        {
          "src": "icon-192.png",
          "sizes": "192x192"
        }
      ],
      "auth": false,
      "update": 3600
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://*.clearledger.vercel.app"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "/?shared=true",
    "method": "GET",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link"
    }
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/?action=add-transaction"
  }
}
